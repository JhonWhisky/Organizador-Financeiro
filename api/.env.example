# String de ligação ao PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Segredo para assinar os tokens JWT. OBRIGATÓRIO — a API não arranca sem ele.
# Gere um com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# CORS: origens permitidas separadas por vírgula (ex.: https://seu-app.vercel.app).
# Vazio = same-origin apenas em produção; em desenvolvimento reflete a origem.
CORS_ORIGIN=

# SMTP para enviar o código de recuperação de senha (opcional em desenvolvimento).
# Sem estas variáveis, o código é registado no log do servidor em vez de enviado.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
