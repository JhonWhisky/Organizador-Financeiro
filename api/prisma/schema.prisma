generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  senha       String

  codigoRecuperacao String?
  expiracaoCodigo   DateTime?
  
  // Relações (Tudo o que pertence a este utilizador)
  responsaveis Responsavel[]
  salarios    Salario[]
  faturas     Fatura[]
  itens       ItemFatura[]
  assinaturas Assinatura[]
  pagamentos  Pagamento[]
  pix         Pix[]
}

model Responsavel {
  id          Int          @id @default(autoincrement())
  nome        String
  
  usuarioId   Int
  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  salarios    Salario[]
  compras     ItemFatura[]
  assinaturas Assinatura[]
  pagamentos  Pagamento[]
  pix         Pix[]

  // O nome da pessoa só é único DENTRO da conta do próprio utilizador
  @@unique([nome, usuarioId])
}

model Salario {
  id            Int         @id @default(autoincrement())
  nome          String
  valor         Float
  
  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Fatura {
  id             Int          @id @default(autoincrement())
  nome           String
  limite         Float
  dataFechamento Int
  dataVencimento Int
  
  usuarioId      Int
  usuario        Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  itens          ItemFatura[]
  assinaturas    Assinatura[]
}

model ItemFatura {
  id            Int         @id @default(autoincrement())
  data          String
  nome          String
  tipo          String
  vezes         Int
  valorTotal    Float
  
  faturaId      Int
  fatura        Fatura      @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  
  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Assinatura {
  id            Int         @id @default(autoincrement())
  nome          String
  valor         Float
  diaCobranca   Int
  
  faturaId      Int
  fatura        Fatura      @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  
  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Pagamento {
  id            Int         @id @default(autoincrement())
  mes           Int
  ano           Int
  valor         Float
  
  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Pix {
  id            Int         @id @default(autoincrement())
  data          String      
  destinatario  String
  valor         Float
  descricao     String
  
  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}