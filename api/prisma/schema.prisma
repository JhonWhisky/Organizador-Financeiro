generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  senha       String

  codigoRecuperacao String?
  expiracaoCodigo   DateTime?

  // Relações (Tudo o que pertence a este utilizador)
  responsaveis Responsavel[]
  salarios    Salario[]
  faturas     Fatura[]
  itens       ItemFatura[]
  assinaturas Assinatura[]
  pagamentos  Pagamento[]
  pix         Pix[]
}

model Responsavel {
  id          Int          @id @default(autoincrement())
  nome        String

  usuarioId   Int
  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  salarios    Salario[]
  compras     ItemFatura[]
  assinaturas Assinatura[]
  pagamentos  Pagamento[]
  pix         Pix[]

  // O nome da pessoa só é único DENTRO da conta do próprio utilizador
  @@unique([nome, usuarioId])
  @@index([usuarioId])
}

model Salario {
  id            Int         @id @default(autoincrement())
  nome          String
  valor         Decimal     @db.Decimal(12, 2)

  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([responsavelId])
}

model Fatura {
  id             Int          @id @default(autoincrement())
  nome           String
  limite         Decimal      @db.Decimal(12, 2)
  dataFechamento Int
  dataVencimento Int

  usuarioId      Int
  usuario        Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  itens          ItemFatura[]
  assinaturas    Assinatura[]

  @@index([usuarioId])
}

model ItemFatura {
  id            Int         @id @default(autoincrement())
  data          DateTime    @db.Date
  nome          String
  tipo          String
  vezes         Int
  valorTotal    Decimal     @db.Decimal(12, 2)

  faturaId      Int
  fatura        Fatura      @relation(fields: [faturaId], references: [id], onDelete: Cascade)

  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([faturaId])
  @@index([responsavelId])
}

model Assinatura {
  id            Int         @id @default(autoincrement())
  nome          String
  valor         Decimal     @db.Decimal(12, 2)
  diaCobranca   Int

  faturaId      Int
  fatura        Fatura      @relation(fields: [faturaId], references: [id], onDelete: Cascade)

  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([faturaId])
  @@index([responsavelId])
}

model Pagamento {
  id            Int         @id @default(autoincrement())
  mes           Int
  ano           Int
  valor         Decimal     @db.Decimal(12, 2)

  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([responsavelId])
}

model Pix {
  id            Int         @id @default(autoincrement())
  data          DateTime    @db.Date
  destinatario  String
  valor         Decimal     @db.Decimal(12, 2)
  descricao     String

  responsavelId Int
  responsavel   Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  usuarioId     Int
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([responsavelId])
}
